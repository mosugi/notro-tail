---
import { Image } from "astro:assets";
import type { PageObjectResponseType } from "../loader/schema.ts";
interface Props {
  cover: PageObjectResponseType["cover"];
  alt?: string;
  class?: string;
}

const { cover, alt, class: className } = Astro.props;

const imageUrl = cover?.type === "file" ? cover?.file.url : cover?.external?.url;
---

{
  imageUrl ? (
    <div class:list={["nt-collection-cover", className]}>
      <Image
        src={imageUrl}
        alt={alt ?? ""}
        width={1200}
        height={630}
      />
    </div>
  ) : null
}
