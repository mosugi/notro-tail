---
import type { BlockWithChildren } from "../loader/loader";

export interface Props {
  blocks: BlockWithChildren[];
}

const { blocks } = Astro.props;

import { Debug } from "astro:components";
import Bookmark from "./Bookmark.astro";
import NumberedListItemContainer from "./NumberedListItemContainer.astro";
import BulletedListItemContainer from "./BulletedListItemContainer.astro";
import Divider from "./Divider.astro";
import TodoListItem from "./TodoListItem.astro";
import NumberedListItem from "./NumberedListItem.astro";
import TodoListItemContainer from "./TodoListItemContainer.astro";
import Column from "./Column.astro";
import Database from "./Database.astro";
import Quote from "./Quote.astro";
import Heading1 from "./Heading1.astro";
import LinkToPage from "./LinkToPage.astro";
import ColumnList from "./ColumnList.astro";
import SyncedBlock from "./SyncedBlock.astro";
import Paragraph from "./Paragraph.astro";
import BulletedListItem from "./BulletedListItem.astro";
import ToggleContainer from "./ToggleContainer.astro";
import Heading3 from "./Heading3.astro";
import OptimizedImage from "./OptimizedImage.astro";
import ChildPage from "./ChildPage.astro";
import Heading2 from "./Heading2.astro";
import CodeOrRawHTML from "./CodeOrRawHTML.astro";
import CalloutOrCustomContainer from "./CalloutOrCustomContainer.astro";
import Block from "./Block.astro";
import { isSameType } from "../utils/notion/utils";
import ListItemContainer from "./ListItemContainer.astro";

let tempListItems: any = [];
---

{
  blocks.map((block, i, array) => {
    let children = null;

    if (block.has_children) {
      children = <Astro.self blocks={block.children} />;
    }

    switch (block.type) {
      case "paragraph":
      case "heading_1":
      case "heading_2":
      case "heading_3":
      case "column_list":
      case "column":
      case "bookmark":
      case "divider":
      case "quote":
      case "code":
        return <Block block={block}>{children}</Block>;
      case "bulleted_list_item":
      case "numbered_list_item":
      case "to_do":
        tempListItems.push(
          <Block block={block}>{children}</Block>)
        if(block.type !== array[i + 1]?.type){
          const container = (
            <ListItemContainer type={block.type}>
              {tempListItems}
            </ListItemContainer>
          )
          tempListItems = [];
          return container;
          }
        return null;
      <!--case "callout":-->
      <!--  // FIXME シンプルに済ませるためCustom機能はNotionBlocks.astroではなく別で書いた方が良いかも-->
      <!--  return (-->
      <!--  <CalloutOrCustomContainer block={block}>-->
      <!--    {children}-->
      <!--  </CalloutOrCustomContainer>-->
      <!--    );-->
      case "synced_block": // TODO 要実装
      case "link_to_page": // TODO 要実装
      case "child_database":
      case "child_page":
      case "template":
      case "toggle":
      case "breadcrumb":
      case "table_of_contents":
      case "table":
      case "table_row":
      case "embed":
      case "video":
      case "audio":
      case "file":
      case "pdf":
      case "equation":
      case "link_preview":
      case "unsupported":
      default:
        console.log("Unknown block type:", block.type);
        <!--return <Debug {block} />-->
        return null;
    }
  })
}
