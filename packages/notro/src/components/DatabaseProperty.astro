---
import RichText from "./RichText.astro";
import type { PropertyPageObjectResponseType } from "../loader/schema.ts";

interface Props {
  property: PropertyPageObjectResponseType;
}

const { property } = Astro.props;
---

<div class="nt-collection-property" data-property-id={property.id}>
  {
    (() => {
      switch (property.type) {
        case "rich_text":
          return (
            property.rich_text && (
              <p class="nt-property-text">
                <RichText richText={property.rich_text} />
              </p>
            )
          );
        case "select":
          return (
            property.select && (
              <span class="nt-property-select">{property.select?.name}</span>
            )
          );
        case "multi_select":
          return (
            property.multi_select.length > 0 && (
              <div class="nt-property-multi-select">
                {property.multi_select.map((item) => {
                  return <span class="nt-property-select">{item.name}</span>;
                })}
              </div>
            )
          );
        case "date":
          return (
            property.date && (
              <time class="nt-property-date" datetime={property.date?.start}>
                {property.date?.start}
              </time>
            )
          );
        case "title":
        case "button":
        case "checkbox":
        case "created_by":
        case "created_time":
        case "email":
        case "files":
        case "formula":
        case "last_edited_by":
        case "last_edited_time":
        case "number":
        case "people":
        case "phone_number":
        case "relation":
        case "rollup":
        case "status":
        case "unique_id":
        case "url":
        case "verification":
        default:
          console.log("Unsupported property type: " + property.type);
          return null;
      }
    })()
  }
</div>
