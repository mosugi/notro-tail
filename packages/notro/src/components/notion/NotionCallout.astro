---
// Component mapping target for <notion-callout> custom elements in Notion markdown content.
interface Props {
  "data-color"?: string;
  icon?: string;
  [key: string]: unknown;
}

const { "data-color": color, icon, ...rest } = Astro.props;

const bgColor: Record<string, string> = {
  gray_background:   "bg-neutral-100",
  brown_background:  "bg-stone-100",
  orange_background: "bg-orange-50",
  yellow_background: "bg-yellow-50",
  green_background:  "bg-green-50",
  blue_background:   "bg-sky-50",
  purple_background: "bg-purple-50",
  pink_background:   "bg-pink-50",
  red_background:    "bg-red-50",
};

const bg = (color && bgColor[color]) ?? "bg-gray-50";
---

<div class:list={["my-3 flex gap-3 rounded-md px-4 py-3 text-sm leading-7", bg]} {...rest}>
  {icon && <span class="shrink-0 select-none">{icon}</span>}
  <div class="min-w-0 flex-1"><slot /></div>
</div>
