---
// Component mapping target for <table> elements in Notion markdown content.
// Wraps the table in a scrollable container for responsive layouts.
interface Props {
  class?: string;
  [key: string]: unknown;
}

const { class: className, ...rest } = Astro.props;
---

<div class="nt-table-wrapper" role="region" tabindex="0">
  <table class:list={["nt-table", className]} {...rest}>
    <slot />
  </table>
</div>
