---
// Component mapping target for <h1> elements in Notion markdown content.
// Adds an anchor link when the element has an id (set by tableOfContentsPlugin).
interface Props {
  id?: string;
  class?: string;
  [key: string]: unknown;
}

const { id, class: className, ...rest } = Astro.props;
---

<h1 id={id} class:list={["nt-h1", className]} {...rest}>
  {id && <a href={`#${id}`} class="nt-heading-anchor" aria-hidden="true">#</a>}
  <slot />
</h1>
