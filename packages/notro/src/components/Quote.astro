---
import RichText from "./RichText.astro";
import type { QuoteBlockObjectResponseType } from "../loader/schema.ts";
interface Props {
  block: QuoteBlockObjectResponseType;
}

const { block } = Astro.props;
---

<blockquote id={block.id} class="nt-selectable nt-quote-block">
  <RichText richText={block.quote.rich_text} />
</blockquote>
