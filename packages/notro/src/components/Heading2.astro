---
import RichText from "./RichText.astro";
import { getNotionColor } from "../utils/notion";
import type { Heading2BlockObjectResponseType } from "../loader/schema.ts";

interface Props {
  block: Heading2BlockObjectResponseType;
}

const { block } = Astro.props;
---

<h3
  id={block.id}
  class=`nt-selectable nt-sub_header-block ${getNotionColor(block.heading_2.color)}`
>
  <RichText richText={block.heading_2.rich_text} />
  <slot />
</h3>
