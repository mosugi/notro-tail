---
import type { CalloutBlockObjectResponse } from "@notionhq/client/build/src/api-endpoints";
import Callout from "./Callout.astro";
import * as console from "node:console";
interface Props {
  block: CalloutBlockObjectResponse;
}

const extractClassString = (input: string): string | undefined => {
  // ASCIIと全角ダブルクォートの両方に対応（Notion側で変換されることがあるため）
  const regex = /^class=["|”]([^"|”]*)["|”]/;
  const match = input.match(regex);
  if (match) {
    return match[1].replace(/\r?\n/g, "");
  }
  return undefined;
};
const { block } = Astro.props;
const classes = extractClassString(block.callout.rich_text[0]?.plain_text);
---

{
  classes !== undefined ? (
    <div class={classes}>
      <slot />
    </div>
  ) : (
    <Callout block={block}>
      <slot />
    </Callout>
  )
}
