---
import type { BlockObjectResponse } from "@notionhq/client/build/src/api-endpoints";
import Paragraph from "./Paragraph.astro";
import ToggleContainer from "./ToggleContainer.astro";
import Heading3 from "./Heading3.astro";
import Heading1 from "./Heading1.astro";
import Heading2 from "./Heading2.astro";
import Column from "./Column.astro";
import ColumnList from "./ColumnList.astro";
import Bookmark from "./Bookmark.astro";
import Divider from "./Divider.astro";
import Quote from "./Quote.astro";
import Image from "./Image.astro";
import Code from "./Code.astro";
import BulletedListItem from "./BulletedListItem.astro";
import NumberedListItem from "./NumberedListItem.astro";
import TodoListItem from "./TodoListItem.astro";
interface Props {
  block: BlockObjectResponse;
}

const { block } = Astro.props;
---

{
  (() => {
    switch (block.type) {
      case "paragraph":
        return (
          <Paragraph block={block}>
            <slot />
          </Paragraph>
        );
      case "heading_1":
        return block.heading_1.is_toggleable ? (
          <ToggleContainer>
            <Heading1 block={block} slot="summary" />
            <slot />
          </ToggleContainer>
        ) : (
          <Heading1 block={block}>
            <slot />
          </Heading1>
        );
      case "heading_2":
        return block.heading_2.is_toggleable ? (
          <ToggleContainer>
            <Heading2 block={block} slot="summary" />
            <slot />
          </ToggleContainer>
        ) : (
          <Heading2 block={block}>
            <slot />
          </Heading2>
        );
      case "heading_3":
        return block.heading_3.is_toggleable ? (
          <ToggleContainer>
            <Heading3 block={block} slot="summary" />
            <slot />
          </ToggleContainer>
        ) : (
          <Heading3 block={block}>
            <slot />
          </Heading3>
        );
      case "column_list":
        return (
          <ColumnList block={block}>
            <slot />
          </ColumnList>
        );
      case "column":
        return (
          <Column block={block}>
            <slot />
          </Column>
        );
      case "bookmark":
        return <Bookmark block={block} />;
      case "divider":
        return <Divider block={block} />;
      case "quote":
        return (
          <Quote block={block}>
            <slot />
          </Quote>
        );
      case "image":
        return <Image block={block} />;
      case "code":
        return <Code block={block} />;
      case "bulleted_list_item":
        return (
          <BulletedListItem block={block}>
            <slot />
          </BulletedListItem>
        );
      case "numbered_list_item":
        return (
          <NumberedListItem block={block}>
            <slot />
          </NumberedListItem>
        );
      case "to_do":
        return (
          <TodoListItem block={block}>
            <slot />
          </TodoListItem>
        );
      default:
        return null;
    }
  })()
}
