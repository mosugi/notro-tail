---
import RichText from "./RichText.astro";
import type { ToDoBlockObjectResponseType } from "../loader/schema.ts";
interface Props {
  block: ToDoBlockObjectResponseType;
}

const { block } = Astro.props;
---

<li id={block.id} class=`nt-selectable nt-to_do-block`>
  <input
    id={block.id + "-input"}
    type="checkbox"
    checked={block.to_do.checked}
    disabled
  />
  <label for={block.id + "-input"}>
    {
      block.to_do.checked ? (
        <s>
          <RichText richText={block.to_do.rich_text} />
        </s>
      ) : (
        <RichText richText={block.to_do.rich_text} />
      )
    }
  </label>
  <slot />
</li>
