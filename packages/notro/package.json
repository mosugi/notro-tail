{
  "name": "notro",
  "description": "A Content loader for Astro that uses the Notion Public API",
  "version": "0.0.1",
  "type": "module",
  "author": "mosugi <mosugeek@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mosugi/NotroTail.git",
    "directory": "packages/notro"
  },
  "keywords": [
    "astro",
    "withastro",
    "astro-component",
    "astro-loader",
    "notion"
  ],
  "bugs": {
    "url": "https://github.com/mosugi/NotroTail/issues"
  },
  "homepage": "https://notrotail.mosugi.com",
  "exports": {
    ".": "./index.ts",
    "./config": "./src/markdown/notroMarkdownConfig.ts"
  },
  "files": [
    "index.ts",
    "src/components",
    "src/loader",
    "src/markdown",
    "src/utils"
  ],
  "scripts": {
    "format": "prettier --write 'src/**/*.ts' 'src/**/*.astro'"
  },
  "devDependencies": {
    "astro": "^5.18.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "provenance": true
  },
  "dependencies": {
    "@notionhq/client": "5.11.1",
    "unified": "^11.0.0",
    "remark-parse": "^11.0.0",
    "remark-gfm": "^4.0.0",
    "remark-directive": "^4.0.0",
    "remark-rehype": "^11.1.2",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.0",
    "hast-util-from-html": "^2.0.0"
  }
}
