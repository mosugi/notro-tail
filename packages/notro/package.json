{
  "name": "notro",
  "description": "A Content loader for Astro that uses the Notion Public API",
  "version": "0.0.1",
  "type": "module",
  "author": "mosugi <mosugeek@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mosugi/NotroTail.git",
    "directory": "packages/notro"
  },
  "keywords": [
    "astro",
    "withastro",
    "astro-component",
    "astro-loader",
    "notion"
  ],
  "bugs": {
    "url": "https://github.com/mosugi/NotroTail/issues"
  },
  "homepage": "https://notrotail.mosugi.com",
  "exports": {
    ".": "./index.ts"
  },
  "files": [
    "index.ts",
    "src/components",
    "src/loader",
    "src/utils"
  ],
  "scripts": {
    "format": "prettier --write 'src/**/*.ts' 'src/**/*.astro'"
  },
  "devDependencies": {
    "astro": "^5.2.5",
    "typescript": "^5.4.5"
  },
  "publishConfig": {
    "provenance": true
  },
  "dependencies": {
    "@notionhq/client": "^2.2.16"
  }
}
